# Neon PostgreSQL — get this from: https://console.neon.tech
# Your project → Connection Details → Connection string
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Vercel Blob — for photo uploads
# Get from: Vercel Dashboard → Storage → Blob → your store → .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxx
